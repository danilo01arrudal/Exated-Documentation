- create database
STEP 12
[root@localhost ~]# systemctl stop postgresql-18.service;
[root@localhost ~]# rm -Rvf /var/lib/pgsql/18/data/*; rm -Rvf /var/lib/pgsql/archivedir; mkdir -p /var/lib/pgsql/archivedir; chown postgres:postgres -R /var/lib/pgsql/archivedir; echo "postgres"> /var/lib/pgsql/pdwfile; chown postgres:postgres /var/lib/pgsql/pdwfile;
[root@localhost ~]# su - postgres -c "/usr/pgsql-18/bin/initdb --locale=pt_BR.UTF-8 -D /var/lib/pgsql/18/data/ --pwfile=/var/lib/pgsql/pdwfile"; systemctl start postgresql-18.service; rm -vf /var/lib/pgsql/pdwfile; echo :5432::postgres:postgres > /var/lib/pgsql/.pgpass;
[root@localhost ~]# chown postgres:postgres /var/lib/pgsql/.pgpass; chmod 0600 /var/lib/pgsql/.pgpass; rm -vf /home/postgres/useraccts.sql

