++++++++++++++++++++++++++++++++++++++++++++++++++++++++++

INSTALL AND CONFIGURE PGPOOL 4.7.0 WITH POSTGRESQL 18 +
++++++++++++++++++++++++++++++++++++++++++++++++++++++++++

#################################################

RUN THE SCRIPT BELOW FOR ALL CLUSTER MACHINES
#################################################

- set static ip on machines
STEP 0
- set hostname
STEP 1                            
[root@pg1 ~]# hostnamectl set-hostname pg1
[root@pg1 ~]# hostnamectl --static                  
[root@pg2 ~]# hostnamectl set-hostname pg2
[root@pg2 ~]# hostnamectl --static

- ter acesso a internet
STEP 2                
[root@pg1 ~]# ping www.google.com
[root@pg2 ~]# ping www.google.com

- configure file /etc/hosts
STEP 3
[root@pg1 ~]# cat >> /etc/hosts <<EOF
192.168.1.122    pg1

192.168.1.123    pg2
192.168.1.121    vip

EOF

- setting the date and time
STEP 4
[root@pg1 ~]# rm -vf /etc/localtime;
[root@pg1 ~]# ln -s /usr/share/zoneinfo/America/Fortaleza /etc/localtime

- disable firewall
STEP 5
[root@localhost ~]# sed -i 's/SELINUX=.*/SELINUX=disabled/' /etc/selinux/config && setenforce 0;
[root@localhost ~]# systemctl stop firewalld && systemctl disable firewalld

- execution permission on the following commands
STEP 6
[root@localhost ~]# chmod u+x /usr/sbin/ip;
[root@localhost ~]# chmod u+s /usr/sbin/arping; chmod u+s /sbin/ip; chmod u+s /sbin/ifconfig

- install package dependencies
STEP 7
[root@localhost ~]# pkill -f "yum";
[root@localhost ~]# yum repolist; yum install -y net-tools openssl-devel rsync; yum install -y https://download.postgresql.org/pub/repos/yum/reporpms/EL-7-x86_64/pgdg-redhat-repo-latest.noarch.rpm; yum install -y postgresql18-contrib.x86_64 postgresql18-libs.x86_64 postgresql18-server.x86_64 postgresql18.x86_64;
[root@localhost ~]# yum install -y https://www.pgpool.net/yum/rpms/4.7/redhat/rhel-7-x86_64/pgpool-II-release-4.7-1.noarch.rpm; yum -y install pgpool-II-pg18 pgpool-II-pg18-debuginfo pgpool-II-pg18-devel pgpool-II-pg18-extensions;

- add entry to the file /etc/environment
STEP 8
echo "PGDATA=/var/lib/pgsql/18/data/" >> /etc/environment
echo "PGHOME=/usr/pgsql-18/" >> /etc/environment

- change postgres user password
STEP 9
[root@pg1 ~]# passwd postgres
[root@pg2 ~]# passwd postgres

[root@pg1 ~]# su - postgres
[postgres@pg1 ~]$ mkdir ~/.ssh;
[postgres@pg1 ~]$ chmod 700 ~/.ssh; touch ~/.ssh/authorized_keys; chmod 600 ~/.ssh/authorized_keys; cd ~/.ssh;
[postgres@pg1 ~]$ ssh-keygen -t rsa -f id_rsa_pgpool
[postgres@pg1 ~]$ exit
[root@pg2 ~]# su - postgres
[postgres@pg2 ~]$ mkdir ~/.ssh; chmod 700 ~/.ssh; touch ~/.ssh/authorized_keys;
[postgres@pg2 ~]$ chmod 600 ~/.ssh/authorized_keys; cd ~/.ssh; ssh-keygen -t rsa -f id_rsa_pgpool
[postgres@pg1 .ssh]# ssh-copy-id -i id_rsa_pgpool.pub postgres@pg2
[postgres@pg1 .ssh]# ssh-copy-id -i id_rsa_pgpool.pub postgres@pg1
[root@pg2 ~]# su - postgres
[postgres@pg2 .ssh]# ssh-copy-id -i id_rsa_pgpool.pub postgres@pg1
[postgres@pg2 .ssh]# ssh-copy-id -i id_rsa_pgpool.pub postgres@pg2

- create environment variable file
STEP 10
[root@localhost ~]# cat > /etc/sysconfig/pgpool <<EOF

Options for pgpool
-n: don't run in daemon mode.
does not detatch control tty
-d: debug mode. lots of debug information will be printed
OPTS=" -d -n"
#OPTS=" -n"

STOP_OPTS=" -m fast"
EOF
chown postgres:postgres /etc/sysconfig/pgpool

- enable pgpool-II service, postgresql-18
STEP 11
[root@localhost ~]# systemctl daemon-reload;
[root@localhost ~]# systemctl enable pgpool.service; systemctl daemon-reload; systemctl enable postgresql-18.service;

